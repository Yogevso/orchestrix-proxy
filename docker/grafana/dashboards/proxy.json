{
  "id": null,
  "uid": "orchestrix-proxy",
  "title": "Orchestrix Proxy",
  "tags": ["proxy", "orchestrix"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(proxy_requests_total[1m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "proxy_active_connections",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "proxy_uptime_seconds",
          "legendFormat": "seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(proxy_status_total[1m])",
          "legendFormat": "{{class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "Overloaded (503) / Rate-Limited (429)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(proxy_overloaded_total[1m])",
          "legendFormat": "overloaded",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_rate_limited_total[1m])",
          "legendFormat": "rate_limited",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 6,
      "title": "Backend Request Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(proxy_backend_requests_total[1m])",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "title": "Backend Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(proxy_backend_failures_total[1m])",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    }
  ]
}
